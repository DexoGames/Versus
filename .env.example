# Firebase web config (public keys — kept out of git anyway).
# Copy to .env and fill in from the Firebase console to enable online play.
# Without these the site works fully offline (CPU + hotseat modes).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
